generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String    @id @default(uuid())
  title     String
  content   String
  pinned    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tagNotes  TagNote[]
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  color    TagColor  @default(GREEN)
  icon     TagIcon   @default(STAR)
  tagNotes TagNote[]
}

model TagNote {
  id     String @id @default(uuid())
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([noteId, tagId])
  @@index([noteId])
  @@index([tagId])
}

enum TagColor {
  RED
  GREEN
  BLUE
  BLACK
  YELLOW
  PURPLE
  ORANGE
  GRAY
}

enum TagIcon {
  STAR
  HEART
  BOOK
  CODE
  CLOCK
  FLAG
  TAG
}
